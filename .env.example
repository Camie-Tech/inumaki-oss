# API
INUMAKI_API_PORT=4141
DATABASE_URL=file:./data/inumaki.sqlite
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=
GROQ_TIMEOUT_MS=20000
SLOW_DICTATION_THRESHOLD_MS=5000

# Local Whisper adapter. Point this to a whisper.cpp-compatible binary.
# Run `pnpm setup:whisper` to install the default managed binary/model under .local/.
WHISPER_CPP_BINARY=
WHISPER_MODEL_PATH=
WHISPER_CPP_HOME=.local/whisper.cpp
WHISPER_CPP_MODEL=base.en
# Leave blank to auto-detect a safe local default.
WHISPER_CPP_THREADS=
WHISPER_CPP_TIMEOUT_MS=120000
# Windows default setup downloads an official prebuilt whisper.cpp release asset.
WHISPER_CPP_WINDOWS_ASSET=whisper-bin-x64.zip
# Set true only when intentionally compiling whisper.cpp locally on Windows.
WHISPER_CPP_BUILD_FROM_SOURCE=false

# Desktop
INUMAKI_API_BASE_URL=http://127.0.0.1:4141
